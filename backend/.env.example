# ── Database ─────────────────────────────────────────────────────
# Railway provides this automatically. For local dev use your own Postgres.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ──────────────────────────────────────────────────────────
# Make this long and random. Never share it.
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_characters

NODE_ENV=production
PORT=4000

# ── Frontend URL (for CORS) ───────────────────────────────────────
FRONTEND_URL=https://your-app.onrender.com

# ── Gmail SMTP (for email verification + forgot password) ─────────
# 1. Go to Google Account → Security → 2-Step Verification → App Passwords
# 2. Generate a new App Password for "Mail"
# 3. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=yoursixteencharacterapppassword

# How the sender name appears in emails
EMAIL_FROM=ResearchTrack <your-gmail@gmail.com>

# Your app's public URL (used in email links)
APP_URL=https://your-app.onrender.com
