# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_characters

NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-app.onrender.com

# ── Superadmin credentials (set before first deploy) ──────────────
# These only take effect when no superadmin exists in the database yet
SUPERADMIN_EMAIL=your-personal-email@gmail.com
SUPERADMIN_PASS=YourStrongPassword@123

# ── Gmail SMTP (optional — add later for email features) ──────────
# Without these, email verification is skipped and password reset
# tokens are printed to the server logs instead.
#
# Setup: Google Account → Security → 2-Step Verification → App Passwords
# Generate a password for "Mail" (16 chars, no spaces)
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-app-gmail@gmail.com
# SMTP_PASS=yoursixteencharacterapppassword
# EMAIL_FROM=ResearchTrack <your-app-gmail@gmail.com>
# APP_URL=https://your-app.onrender.com
